birdTerrY <- newMate(birdTerrY, dfBird, dfTerr, pFidel, i, pObs, pMate)
birdTerrY <- makeFledge(birdTerrY, maxFledge)
dfSim <- rbind(dfSim, birdTerrY)
}
return(dfSim)
}
